---
apiVersion: v1
kind: Secret
metadata:
  name: mosquitto-admin-pw
type: Opaque
stringData:
  # Example credential is admin:admin. Use create_credentials.sh to create creative credentials. 
  passwd-file: |
    admin:$7$101$JStajGAGbjIWzY/Z$qBfDW+1pW9YCLIAU3OZDMHyld2ua/98XaBGffxfcAyfugpsDoyIeS9CYHD/BpVkssa2IzIgvURnXP3o8OQHMuA==
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: mosquitto-config
data:
  mosquitto-conf: |
    # =================================================================
    # General Settings
    # =================================================================
    # Save in-flight messages to a persistent database on disk
    persistence true
    persistence_location /var/lib/mosquitto/

    # Log locations and message types to capture
    log_dest file /mosquitto/log/mosquitto.log
    log_type error
    log_type warning
    log_type notice
    log_type information


    # Default Unencrypted Listener (Local or LAN)
    listener 1883 0.0.0.0
    protocol mqtt

    # Security Settings
    # Disable anonymous access (highly recommended for production)
    allow_anonymous false
    password_file /mosquitto/passwd

    # WebSockets Listener (Useful for web dashboard clients)
    listener 9001 0.0.0.0
    protocol websockets
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: mosquitto
spec:
  selector:
    matchLabels:
      server: mosquitto
  template:
    metadata:
      labels:
        server: mosquitto
    spec:
      securityContext:
        runAsUser: 1883       
        runAsGroup: 1883     
        fsGroup: 1883     
      volumes:
        - name: mosqitto-conf-vol
          configMap:
            name: mosquitto-config
            items: 
              - key: mosquitto-conf
                path: mosquitto.conf
        - name: mosquitto-passwd # for copying content to emptyDir
          secret:
            secretName: mosquitto-admin-pw
            items:
            - key: passwd-file
              path: passwd
        - name: passwd-writeable
          emptyDir: {}

      initContainers:
      - name: change-passws-file
        image: eclipse-mosquitto:openssl
        command: 
          - sh
          - -c
          - |
              cp /secret/passwd /passwd-writeable/passwd
              chown 1883:1883 /passwd-writeable/passwd
              chmod 0600 /passwd-writeable/passwd
        volumeMounts:
          - name: mosquitto-passwd
            mountPath: /secret
          - name:  passwd-writeable
            mountPath: /passwd-writeable
      containers:
      - name: mosquitto-container
        image: eclipse-mosquitto:openssl
        securityContext:
          runAsUser: 1883
        resources:
          limits:
            memory: "128Mi"
            cpu: "250m"
        ports:
        - name: mqtt-notls
          containerPort: 1883 #Unencrypted Listener (Local or LAN)
          protocol: TCP
        - name: mqtt-ws
          containerPort: 9001 #WebSockets Listener (Useful for web dashboard clients)
          protocol: TCP
        volumeMounts:
          - name: mosqitto-conf-vol
            mountPath: /mosquitto/config/mosquitto.conf
            subPath: mosquitto.conf 
          - name: passwd-writeable
            mountPath: /mosquitto/passwd
            subPath: passwd
---
apiVersion: v1
kind: Service
metadata:
  name: mosquitto-svc
spec:
  type: NodePort
  selector:
    server: mosquitto
  ports:
  - name: mqtt-notls-access
    port: 1883
    nodePort: 31883
    targetPort: mqtt-notls
  - name: mqtt-websocket-access
    port: 9001
    nodePort: 31885
    targetPort: mqtt-ws
---